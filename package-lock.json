{
  "name": "siftvault",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "siftvault",
      "version": "0.0.0",
      "workspaces": [
        "client",
        "server"
      ],
      "engines": {
        "node": ">=22"
      }
    },
    "client": {
      "name": "@siftvault/client",
      "version": "0.0.0"
    },
    "node_modules/@siftvault/client": {
      "resolved": "client",
      "link": true
    },
    "node_modules/@siftvault/server": {
      "resolved": "server",
      "link": true
    },
    "server": {
      "name": "@siftvault/server",
      "version": "0.0.0"
    }
  }
}
